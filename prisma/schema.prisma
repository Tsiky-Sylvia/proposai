generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  email     String     @unique
  name      String?
  company   String?
  createdAt DateTime   @default(now())
  proposals Proposal[]
}

model Proposal {
  id            String          @id @default(cuid())
  title         String
  rawInput      String
  clientName    String
  clientEmail   String
  clientCompany String?
  context       String
  deliverables  String
  timeline      String
  pricing       String
  conditions    String
  amount        Float
  currency      String          @default("EUR")
  status        ProposalStatus  @default(DRAFT)
  publicToken   String          @unique @default(cuid())
  signedAt      DateTime?
  signatureData String?
  signedIp      String?
  validUntil    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  events        ProposalEvent[]
}

model ProposalEvent {
  id         String    @id @default(cuid())
  type       EventType
  metadata   String?
  createdAt  DateTime  @default(now())
  proposalId String
  proposal   Proposal  @relation(fields: [proposalId], references: [id])
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum EventType {
  CREATED
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}
